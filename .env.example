# Variables de Entorno
# Copia este archivo a .env.local y completa con tus valores

# API Base URL (si implementas backend)
VITE_API_URL=http://localhost:3001

# Google Analytics
VITE_GOOGLE_ANALYTICS_ID=

# Stripe (si implementas pagos con Stripe)
VITE_STRIPE_PUBLIC_KEY=

# PayPal
VITE_PAYPAL_CLIENT_ID=

# Email para contacto
VITE_CONTACT_EMAIL=info@dimple.com

# WhatsApp
VITE_WHATSAPP_NUMBER=

# Modo
VITE_MODE=development
